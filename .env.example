# Base RPC — wss для подписки на блоки (Alchemy / QuickNode / свой нод)
RPC_URL=
CHAIN=base
# Base mainnet = 8453, Base Sepolia = 84532
CHAIN_ID=8453
# Кошелёк — только газ (flash-loan не держит средств). Ключ НЕ коммитить.
WALLET_ADDRESS=
WALLET_KEY=
# Режим: monitor (paper-trade) | execute
MODE=monitor
COVERED_MARKETS_PATH=covered_markets.json
MIN_PROFIT_USD=5.0
MAX_DAILY_LOSS_USD=50
MAX_DAILY_GAS_USD=100
MAX_INFLIGHT=1
TG_BOT_TOKEN=
TG_ADMIN_ID=
ALERT_ANTIFLOOD_SEC=600
POLL_INTERVAL_SEC=2.0
DB_PATH=liquidator.db
LOG_LEVEL=INFO
